# ─── Database ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/ghana_tax_db
MONGO_DB_NAME=ghana_tax_db

# ─── Cache / Sessions ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Set to False to use in-memory cache when Redis is not running locally
USE_REDIS_CACHE=False
# Reports summary cache TTL in seconds
REPORTS_CACHE_TTL=45

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-use-a-long-random-string-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=changeme-use-a-long-random-string-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Africa's Talking (USSD / SMS) ───────────────────────────────────────────
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=GH-REVENUE

# ─── Demo Seed Accounts ───────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=sysadmin@demo.gov.gh
SEED_ADMIN_PASSWORD=DemoPass123!
